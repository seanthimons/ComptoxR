{
  "openapi": "3.0.3",
  "info": {
    "title": "ARN Cats API",
    "version": "1.0",
    "description": "API allows generating a set of ARN categories via GET (one chemical) or POST (multiple chemicals)"
  },
  "paths": {
    "/api/arn_cats/version": {
      "get": {
        "operationId": "app.get_version",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/arn_cats/metadata": {
      "get": {
        "operationId": "app.get_metadata",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/arn_cats": {
      "get": {
        "operationId": "app.get_cats",
        "summary": "Generate an ARN category for one molecule",
        "parameters": [
          {
            "name": "smiles",
            "in": "query",
            "description": "SMILES to generate groups for",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "existing_ARNs": {
                "summary": "SMILES that generates one of the 56 ARN groups",
                "value": "CC(C)c1ccc2sc3ccccc3c(=O)c2c1"
              },
              "other_ARNs": {
                "summary": "Miscellaneous chemistry",
                "value": "c1ccc(OP(Oc2ccccc2)Oc2ccccc2)cc1"
              }
            }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Model to use for group prediction",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "RF",
                "NN"
              ],
              "default": "RF"
            },
            "examples": {
              "default_model": {
                "summary": "Default RF prediction model",
                "value": "RF"
              },
              "alternative_model": {
                "summary": "Alternative DNN-based prediction model",
                "value": "NN"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns a calculated group or error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "chemical": {
                          "type": "object",
                          "description": "Chemical payload enriched via the resolver lookup API when resolution succeeds; otherwise a fallback payload is returned.",
                          "properties": {
                            "id": {
                              "oneOf": [
                                {
                                  "type": "integer"
                                },
                                {
                                  "type": "string"
                                }
                              ]
                            },
                            "chemId": {
                              "type": "string",
                              "nullable": true
                            },
                            "cid": {
                              "type": "string",
                              "nullable": true
                            },
                            "sid": {
                              "type": "string",
                              "nullable": true
                            },
                            "casrn": {
                              "type": "string",
                              "nullable": true
                            },
                            "name": {
                              "type": "string",
                              "nullable": true
                            },
                            "smiles": {
                              "type": "string"
                            },
                            "canonicalSmiles": {
                              "type": "string"
                            },
                            "inchi": {
                              "type": "string",
                              "nullable": true
                            },
                            "inchiKey": {
                              "type": "string",
                              "nullable": true
                            },
                            "additionalProps": {
                              "type": "object"
                            }
                          },
                          "required": [
                            "smiles",
                            "canonicalSmiles",
                            "additionalProps"
                          ],
                          "additionalProperties": false
                        },
                        "result": {
                          "type": "object",
                          "properties": {
                            "in_domain": {
                              "type": "boolean"
                            },
                            "group": {
                              "type": "string",
                              "nullable": true
                            },
                            "probability": {
                              "type": "number",
                              "nullable": true
                            }
                          },
                          "required": [
                            "in_domain",
                            "group",
                            "probability"
                          ],
                          "additionalProperties": false
                        },
                        "error": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "message"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "chemical"
                      ],
                      "additionalProperties": false
                    },
                    "error": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "message"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "result"
                  ],
                  "additionalProperties": false
                },
                "example": {
                  "result": {
                    "chemical": {
                      "chemId": "resolved-chem-id",
                      "cid": "resolved-cid",
                      "sid": "resolved-sid",
                      "casrn": "resolved-casrn",
                      "name": "Resolved Chemical",
                      "smiles": "CC(C)c1ccc2sc3ccccc3c(=O)c2c1",
                      "canonicalSmiles": "CC(C)c1ccc2sc3ccccc3c(=O)c2c1",
                      "inchi": "resolved-inchi",
                      "inchiKey": "resolved-inchikey",
                      "additionalProps": {}
                    },
                    "result": {
                      "in_domain": true,
                      "group": "predicted-group",
                      "probability": 0.92
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "app.post_cats",
        "summary": "Generate groups for multiple molecules",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "smiles": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of SMILES strings, same input style as amnb_nate."
                  },
                  "chemicals": {
                    "type": "array",
                    "items": {},
                    "description": "Either an array of SMILES strings for backward compatibility or an array of objects with id and smiles."
                  },
                  "model": {
                    "type": "string",
                    "enum": [
                      "RF",
                      "NN"
                    ],
                    "default": "RF"
                  }
                },
                "additionalProperties": false
              },
              "examples": {
                "smilesRequest": {
                  "value": {
                    "smiles": [
                      "FC(C(C(C1OC(=O)C2C(=CC=CC=2)N=1)(F)F)(F)F)(F)F",
                      "CCCCN"
                    ],
                    "model": "RF"
                  }
                },
                "chemicalsRequest": {
                  "value": {
                    "chemicals": [
                      {
                        "id": 1,
                        "smiles": "FC(C(C(C1OC(=O)C2C(=CC=CC=2)N=1)(F)F)(F)F)(F)F"
                      },
                      {
                        "id": "ext-2",
                        "smiles": "CCCCN"
                      }
                    ],
                    "model": "NN"
                  }
                },
                "legacyChemicalsRequest": {
                  "value": {
                    "chemicals": [
                      "FC(C(C(C1OC(=O)C2C(=CC=CC=2)N=1)(F)F)(F)F)(F)F",
                      "CCCCN"
                    ],
                    "model": "RF"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns calculated groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "chemical": {
                            "type": "object",
                            "description": "Chemical payload enriched via the resolver lookup API when resolution succeeds; otherwise a fallback payload is returned.",
                            "properties": {
                              "id": {
                                "oneOf": [
                                  {
                                    "type": "integer"
                                  },
                                  {
                                    "type": "string"
                                  }
                                ]
                              },
                              "chemId": {
                                "type": "string",
                                "nullable": true
                              },
                              "cid": {
                                "type": "string",
                                "nullable": true
                              },
                              "sid": {
                                "type": "string",
                                "nullable": true
                              },
                              "casrn": {
                                "type": "string",
                                "nullable": true
                              },
                              "name": {
                                "type": "string",
                                "nullable": true
                              },
                              "smiles": {
                                "type": "string"
                              },
                              "canonicalSmiles": {
                                "type": "string"
                              },
                              "inchi": {
                                "type": "string",
                                "nullable": true
                              },
                              "inchiKey": {
                                "type": "string",
                                "nullable": true
                              },
                              "additionalProps": {
                                "type": "object"
                              }
                            },
                            "required": [
                              "smiles",
                              "canonicalSmiles",
                              "additionalProps"
                            ],
                            "additionalProperties": false
                          },
                          "result": {
                            "type": "object",
                            "properties": {
                              "in_domain": {
                                "type": "boolean"
                              },
                              "group": {
                                "type": "string",
                                "nullable": true
                              },
                              "probability": {
                                "type": "number",
                                "nullable": true
                              }
                            },
                            "required": [
                              "in_domain",
                              "group",
                              "probability"
                            ],
                            "additionalProperties": false
                          },
                          "error": {
                            "type": "object",
                            "properties": {
                              "message": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "message"
                            ],
                            "additionalProperties": false
                          }
                        },
                        "required": [
                          "chemical"
                        ],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": [
                    "results"
                  ],
                  "additionalProperties": false
                },
                "example": {
                  "results": [
                    {
                      "chemical": {
                        "id": 1,
                        "chemId": "resolved-chem-id",
                        "cid": "resolved-cid",
                        "sid": "resolved-sid",
                        "casrn": "resolved-casrn",
                        "name": "Resolved Chemical",
                        "smiles": "FC(C(C(C1OC(=O)C2C(=CC=CC=2)N=1)(F)F)(F)F)(F)F",
                        "canonicalSmiles": "O=C1OC(=NC2=CC=CC=C21)C(F)(F)C(F)(F)C(F)(F)F",
                        "inchi": "resolved-inchi",
                        "inchiKey": "resolved-inchikey",
                        "additionalProps": {}
                      },
                      "result": {
                        "in_domain": true,
                        "group": "predicted-group",
                        "probability": 0.71
                      }
                    },
                    {
                      "chemical": {
                        "id": "ext-2",
                        "chemId": {},
                        "cid": {},
                        "sid": {},
                        "casrn": {},
                        "name": {},
                        "smiles": "invalid",
                        "canonicalSmiles": "invalid",
                        "inchi": {},
                        "inchiKey": {},
                        "additionalProps": {}
                      },
                      "error": {
                        "message": "ARN category cannot be derived"
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
