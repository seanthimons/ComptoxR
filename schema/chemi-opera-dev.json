                              "type": "string",
                              "nullable": true
                            },
                            "smiles": {
                              "type": "string"
                            },
                            "canonicalSmiles": {
                              "type": "string"
                            },
                            "inchi": {
                              "type": "string",
                              "nullable": true
                            },
                            "inchiKey": {
                              "type": "string",
                              "nullable": true
                            },
                            "additionalProps": {
                              "type": "object",
                              "properties": {
                                "moleculeId": {
                                  "oneOf": [
