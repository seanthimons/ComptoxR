          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "modelDetails": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "description": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        },
                        "path": {
                          "type": "string"
                        }
                      }
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "chemical": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "oneOf": [
                                {
                                  "type": "integer"
                                },
                                {
                                  "type": "string"
                                }
                              ]
                            },
                            "chemId": {
                              "type": "string",
                              "nullable": true
                            },
                            "cid": {
                              "type": "string",
                              "nullable": true
                            },
                            "sid": {
                              "type": "string",
                              "nullable": true
                            },
                            "casrn": {
                              "type": "string",
                              "nullable": true
                            },
