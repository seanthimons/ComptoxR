          {
            "name": "smiles",
            "in": "query",
            "description": "SMILES to generate predictions for",
            "required": true,
            "schema": {
              "type": "string"
            },
            "examples": {
              "example1": {
                "summary": "50-01-1",
                "value": "NC(N)=N"
              },
              "example2": {
                "summary": "50-02-2",
                "value": "CC1CC2C3CCC4=CC(=O)C=CC4(C)C3(F)C(O)CC2(C)C1(O)C(=O)CO"
              },
              "example3": {
                "summary": "50-12-4",
                "value": "CCC1(NC(=O)N(C)C1=O)c1ccccc1"
              }
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Format to return predictions in (json, csv, xlsx)",
            "schema": {
              "type": "string",
              "default": "json"
            },
            "examples": {
              "example1": {
                "summary": "CSV",
                "value": "csv"
              },
              "example2": {
                "summary": "JSON",
                "value": "json"
              },
              "example3": {
                "summary": "Excel",
                "value": "xlsx"
              }
            }
          },
          {
            "name": "standardize",
            "in": "query",
            "description": "Standardize chemical before calculating predictions",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
